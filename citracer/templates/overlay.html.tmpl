  #citracer-info.pinned::before {
    content: "📌 pinned — click the node again or × to unpin";
    display: block; font-size: 10px; color: #06c; margin-bottom: 6px;
  }
  #citracer-info-close {
    position: absolute; top: 6px; right: 10px;
    color: #888; font-size: 22px; line-height: 1; cursor: pointer;
    user-select: none; font-weight: 300;
  }
  #citracer-info-close:hover { color: #222; }
  #citracer-info.empty { display: none; }
