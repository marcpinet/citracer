  <div style="margin-top:4px;color:#aaa;font-size:10px;">Click the command to copy. <span id="citracer-supply-close" style="color:#6cf;cursor:pointer;text-decoration:underline;">Dismiss</span></div>
</div>

<script>
(function() {
  const NODE_DETAILS = {{NODE_DETAILS_JSON}};
  const ANALYTICS = {{ANALYTICS_JSON}};
  const KEYWORD_SPECS = {{KEYWORD_SPECS_JSON}};  // [{keyword, pattern, color}, ...]
  const disabledStatus = new Set({{DEFAULT_DISABLED_JSON}});
  // Edge type filter: secondary (bibliographic) edges start hidden
  const disabledEdgeTypes = new Set(["secondary"]);
  const expandedHits = new Set();
  const expandedAbstracts = new Set();
  // Nodes the user has explicitly hidden via right-click. Independent of
  // the legend status filter — both are OR'd together in applyFilter().
  const manuallyHidden = new Set();

  // ---- persistence ---------------------------------------------------
  // Session key derived from the set of node ids, so:
  //   - refreshing the page reloads the same state
  //   - re-running citracer with different papers gets a fresh state
  //   - re-running with the SAME set of papers still reloads state
  function _sessionHash() {
    const ids = Object.keys(NODE_DETAILS).sort().join("|");
    let h = 0x811c9dc5;
    for (let i = 0; i < ids.length; i++) {
      h ^= ids.charCodeAt(i);
      h = (h + ((h << 1) + (h << 4) + (h << 7) + (h << 8) + (h << 24))) >>> 0;
    }
    return h.toString(36);
  }
  const STATE_KEY = "citracer:" + _sessionHash();
  let saveTimer = null;
  let stateLoaded = false;

  // --- Undo / Redo history ---
  const _undoStack = [];
  const _redoStack = [];
  const _MAX_UNDO = 50;

  function _captureSnapshot() {
    const positions = (typeof network !== 'undefined' && network)
      ? network.getPositions() : {};
    return {
      positions: JSON.parse(JSON.stringify(positions)),
      disabledStatus: Array.from(disabledStatus),
      disabledEdgeTypes: Array.from(disabledEdgeTypes),
      manuallyHidden: Array.from(manuallyHidden),
      layout: currentLayout,
      sizeMode: currentSizeMode,
      spread: currentSpread,
      curvedEdges: curvedEdges,
    };
  }

  function _applySnapshot(snap) {
    // Positions
    if (snap.positions && typeof network !== 'undefined' && network) {
      const updates = [];
      for (const id in snap.positions) {
        const p = snap.positions[id];
        if (p && typeof p.x === 'number' && typeof p.y === 'number') {
          updates.push({ id: id, x: p.x, y: p.y });
        }
      }
      if (updates.length) nodes.update(updates);
    }
    // Filters
    disabledStatus.clear();
    snap.disabledStatus.forEach(s => disabledStatus.add(s));
    disabledEdgeTypes.clear();
    snap.disabledEdgeTypes.forEach(t => disabledEdgeTypes.add(t));
    manuallyHidden.clear();
    snap.manuallyHidden.forEach(i => manuallyHidden.add(i));
    // Controls
    currentLayout = snap.layout;
    currentSizeMode = snap.sizeMode;
    currentSpread = snap.spread;
    curvedEdges = snap.curvedEdges;
    // Sync UI
    const layoutSel = document.getElementById('citracer-layout');
    if (layoutSel) layoutSel.value = currentLayout;
    const sizeSel = document.getElementById('citracer-size');
    if (sizeSel) sizeSel.value = currentSizeMode;
    const spreadSl = document.getElementById('citracer-spread');
    if (spreadSl) spreadSl.value = String(currentSpread);
    const curvedCb = document.getElementById('citracer-curved');
    if (curvedCb) curvedCb.checked = curvedEdges;
    document.querySelectorAll('.legend-item').forEach(el => {
      const s = el.getAttribute('data-status');
      el.classList.toggle('disabled', disabledStatus.has(s));
    });
    document.querySelectorAll('.legend-edge-toggle').forEach(el => {
      const t = el.getAttribute('data-edge-type');
      el.classList.toggle('disabled', disabledEdgeTypes.has(t));
    });
    applyFilter();
    applyCurvedEdges();
  }

  function _pushUndo() {
    _undoStack.push(_captureSnapshot());
    if (_undoStack.length > _MAX_UNDO) _undoStack.shift();
    _redoStack.length = 0;  // clear redo on new action
  }

  function undo() {
    if (_undoStack.length === 0) return;
    _redoStack.push(_captureSnapshot());
    _applySnapshot(_undoStack.pop());
  }

  function redo() {
    if (_redoStack.length === 0) return;
    _undoStack.push(_captureSnapshot());
    _applySnapshot(_redoStack.pop());
  }

  function saveState() {
    // Debounce so rapid events (slider drag, physics settling) don't spam
    // localStorage writes.
    if (saveTimer) clearTimeout(saveTimer);
    saveTimer = setTimeout(() => {
      _pushUndo();
      try {
        const positions = (typeof network !== 'undefined' && network)
          ? network.getPositions() : {};
        const state = {
          v: 1,
          positions: positions,
          pinned: pinnedNodeId,
          disabledStatus: Array.from(disabledStatus),
          disabledEdgeTypes: Array.from(disabledEdgeTypes),
          manuallyHidden: Array.from(manuallyHidden),
          layout: currentLayout,
          sizeMode: currentSizeMode,
          spread: currentSpread,
          curvedEdges: curvedEdges,
        };
        localStorage.setItem(STATE_KEY, JSON.stringify(state));
        const reset = document.getElementById('citracer-reset');
        if (reset) reset.classList.add('saved');
      } catch (e) {
        // quota exceeded / privacy mode / etc. — silently ignore
      }
    }, 300);
  }

  function loadState() {
    try {
      const raw = localStorage.getItem(STATE_KEY);
      if (!raw) return null;
      const state = JSON.parse(raw);
      return state && state.v === 1 ? state : null;
    } catch (e) {
      return null;
    }
  }

  function clearState() {
    try { localStorage.removeItem(STATE_KEY); } catch (e) {}
    const reset = document.getElementById('citracer-reset');
    if (reset) reset.classList.remove('saved');
  }

  function applyLoadedState(state) {
    // Apply filter / toggle state BEFORE positions so that applyFilter()
    // can recompute sizes against the restored visibility set.
    if (state.disabledStatus) {
      disabledStatus.clear();
      state.disabledStatus.forEach(s => disabledStatus.add(s));
    }
    if (state.disabledEdgeTypes) {
      disabledEdgeTypes.clear();
      state.disabledEdgeTypes.forEach(t => disabledEdgeTypes.add(t));
    }
    if (state.manuallyHidden) {
      manuallyHidden.clear();
      state.manuallyHidden.forEach(i => manuallyHidden.add(i));
    }

    // Sync UI classes to match the restored filter state
    document.querySelectorAll('.legend-item').forEach(el => {
      const s = el.getAttribute('data-status');
      el.classList.toggle('disabled', disabledStatus.has(s));
    });
    document.querySelectorAll('.legend-edge-toggle').forEach(el => {
      const t = el.getAttribute('data-edge-type');
      el.classList.toggle('disabled', disabledEdgeTypes.has(t));
    });

    // Dropdowns
    if (state.layout) {
      currentLayout = state.layout;
      const sel = document.getElementById('citracer-layout');
      if (sel) sel.value = state.layout;
    }
    if (state.sizeMode) {
      currentSizeMode = state.sizeMode;
      const sel = document.getElementById('citracer-size');
      if (sel) sel.value = state.sizeMode;
    }
    if (typeof state.spread === 'number') {
      currentSpread = state.spread;
      const slider = document.getElementById('citracer-spread');
      if (slider) slider.value = String(state.spread);
    }
    if (typeof state.curvedEdges === 'boolean') {
      curvedEdges = state.curvedEdges;
      const cb = document.getElementById('citracer-curved');
      if (cb) cb.checked = curvedEdges;
    }

    // Restored positions are applied in tryAttach() (needs the network)
  }
  let currentNodeId = null;
  let pinnedNodeId = null;  // when set, hover updates are ignored
  const DEFAULT_LAYOUT = "{{DEFAULT_LAYOUT}}";
  let currentLayout = DEFAULT_LAYOUT;
  let currentSizeMode = "in-degree";
  let currentSpread = 1.0;  // multiplier applied on top of the layout's natural spacing
  let curvedEdges = true;   // whether edges use smooth curves or straight lines

  // Compile one regex per keyword so we can colour matches individually.
  const KEYWORD_REGEXES = KEYWORD_SPECS.map(s => {
    try {
      return { regex: new RegExp(s.pattern, 'gi'), color: s.color, keyword: s.keyword };
    } catch (e) {
      console.warn('citracer: regex compile failed for', s.keyword, e);
      return null;
    }
  }).filter(Boolean);

  function escapeHtml(s) {
    if (s == null) return '';
    return String(s).replace(/[&<>"']/g, c => ({
      '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
    }[c]));
  }

  function highlightKeyword(text) {
    // Collect every match across every keyword, then render them in
    // sorted order so overlapping spans don't corrupt the output.
    const safe = escapeHtml(text);
    if (!KEYWORD_REGEXES.length) return safe;
    const spans = [];
    for (const kr of KEYWORD_REGEXES) {
      kr.regex.lastIndex = 0;
      let m;
      while ((m = kr.regex.exec(safe)) !== null) {
        spans.push({ start: m.index, end: m.index + m[0].length, color: kr.color });
        if (m[0].length === 0) kr.regex.lastIndex++;  // avoid zero-width loop
      }
    }
    if (!spans.length) return safe;
    // Sort by start, drop overlaps (keep the earliest hit).
    spans.sort((a, b) => a.start - b.start || a.end - b.end);
    const nonOverlapping = [];
    let lastEnd = -1;
    for (const s of spans) {
      if (s.start >= lastEnd) {
        nonOverlapping.push(s);
        lastEnd = s.end;
      }
    }
    // Stitch the result.
    let out = "";
    let cursor = 0;
    for (const s of nonOverlapping) {
      out += safe.slice(cursor, s.start);
      out += '<mark style="background:' + s.color + '">'
           + safe.slice(s.start, s.end)
           + '</mark>';
      cursor = s.end;
    }
    out += safe.slice(cursor);
    return out;
  }

  function renderMath(el) {
    if (typeof renderMathInElement === 'function') {
      try {
        renderMathInElement(el, {
          delimiters: [
            {left: '$$', right: '$$', display: true},
            {left: '$',  right: '$',  display: false},
            {left: '\\(', right: '\\)', display: false},
            {left: '\\[', right: '\\]', display: true},
          ],
          throwOnError: false,
        });
      } catch (e) { /* ignore */ }
    }
  }

  function edgeType(e) {
    // Secondary edges are added with `dashes: true`; primary edges aren't.
    return e && e.dashes ? "secondary" : "primary";
  }

  function sizeForNode(nodeId, inDegree) {
    const d = NODE_DETAILS[nodeId] || {};
    const nm = (ANALYTICS.node_metrics || {})[nodeId] || {};
    let base;
    if (currentSizeMode === "keyword-hits") {
      base = 18 + 3 * ((d.keyword_hits && d.keyword_hits.length) || 0);
    } else if (currentSizeMode === "pagerank") {
      // Scale PageRank (typically 0-1) to a visible size range
      base = 16 + 200 * Math.sqrt(nm.pagerank || 0);
    } else if (currentSizeMode === "betweenness") {
      base = 16 + 120 * Math.sqrt(nm.betweenness || 0);
    } else {
      base = 16 + 6 * Math.sqrt(inDegree || 0);
    }
    if (d.status === "root") base = Math.max(base, 30);
    return Math.min(base, 80);
  }

  // Original smooth settings per edge type, used when curvedEdges is on.
  const SMOOTH_PRIMARY   = {type: "cubicBezier", forceDirection: "vertical", roundness: 0.4};
  const SMOOTH_SECONDARY = {type: "curvedCW", roundness: 0.25};

  function _smoothForEdge(e) {
    if (!curvedEdges) return false;
    return edgeType(e) === "secondary" ? SMOOTH_SECONDARY : SMOOTH_PRIMARY;
  }

  function applyCurvedEdges() {
    if (typeof edges === 'undefined') return;
    const updates = [];
    edges.forEach(e => { updates.push({ id: e.id, smooth: _smoothForEdge(e) }); });
    edges.update(updates);
  }

  function applyFilter() {
    if (typeof nodes === 'undefined' || typeof edges === 'undefined') return;
    // Nodes: hidden if status filter OR manual right-click hide
    const nodeHidden = {};
    const nodeUpdates = [];
    nodes.forEach(n => {
      const d = NODE_DETAILS[n.id];
      const effectiveStatus = (d && d.is_new) ? "new" : (d ? d.status : "pending");
      const statusHidden = disabledStatus.has(effectiveStatus);
      const manualHidden = manuallyHidden.has(n.id);
      const hidden = statusHidden || manualHidden;
      nodeHidden[n.id] = hidden;
      nodeUpdates.push({ id: n.id, hidden: hidden });
    });
    nodes.update(nodeUpdates);

    // Update the "show N manually hidden" banner
    const banner = document.getElementById('citracer-hidden-banner');
    if (banner) {
      if (manuallyHidden.size === 0) {
        banner.classList.add('empty');
      } else {
        banner.classList.remove('empty');
        banner.textContent = 'show ' + manuallyHidden.size + ' manually hidden';
      }
    }
    // Edges: hide by edge type, AND respect node visibility.
    // Also enforce the current smooth/straight preference so toggling
    // nodes doesn't cause edges to flicker between curved and straight.
    const edgeUpdates = [];
    const inDegree = {};
    nodes.forEach(n => { inDegree[n.id] = 0; });
    edges.forEach(e => {
      const typeHidden = disabledEdgeTypes.has(edgeType(e));
      const endpointHidden = nodeHidden[e.from] || nodeHidden[e.to];
      const hidden = typeHidden || endpointHidden;
      edgeUpdates.push({ id: e.id, hidden: hidden, smooth: _smoothForEdge(e) });
      if (!hidden) {
        inDegree[e.to] = (inDegree[e.to] || 0) + 1;
      }
    });
    edges.update(edgeUpdates);
    // Recompute sizes from the visible in-degree we just counted
    const sizeUpdates = [];
    nodes.forEach(n => {
      if (nodeHidden[n.id]) return;
      const newSize = sizeForNode(n.id, inDegree[n.id] || 0);
      if (n.size !== newSize) sizeUpdates.push({ id: n.id, size: newSize });
    });
    if (sizeUpdates.length) nodes.update(sizeUpdates);
    // Recompute visible counts
    let visibleNodes = 0;
    nodes.forEach(n => { if (!n.hidden) visibleNodes++; });
    let visibleEdges = 0;
    edges.forEach(e => { if (!e.hidden) visibleEdges++; });
    const counts = document.getElementById('citracer-counts');
    if (counts) counts.textContent = visibleNodes + ' papers · ' + visibleEdges + ' citations';
  }

  // --- Layout switching ------------------------------------------------

  // Physics parameters must be tuned to the graph size. BarnesHut-style
  // repulsion scales with N² and a constant tuned for 20 nodes will
  // literally throw 1000 nodes off the screen. These helpers pick
  // appropriate values so the simulation stays bounded regardless of
  // graph size.
  function _tierForSize(n) {
    if (n <= 60)   return "small";
    if (n <= 200)  return "medium";
    if (n <= 600)  return "large";
    return "huge";
  }

  function _barnesHutParams(n) {
    // Weaker repulsion + stronger central gravity as N grows, so the
    // simulation has something to bound it and can't blow up.
    switch (_tierForSize(n)) {
      case "small":  return {
        gravitationalConstant: -30000, centralGravity: 0.15,
        springLength: 260, springConstant: 0.04,
        damping: 0.6, avoidOverlap: 1.0,
      };
      case "medium": return {
        gravitationalConstant: -12000, centralGravity: 0.30,
        springLength: 200, springConstant: 0.04,
        damping: 0.7, avoidOverlap: 0.9,
      };
      case "large":  return {
        gravitationalConstant: -5000, centralGravity: 0.55,
        springLength: 160, springConstant: 0.05,
        damping: 0.85, avoidOverlap: 0.7,
      };
      case "huge":   return {
        gravitationalConstant: -2500, centralGravity: 0.85,
        springLength: 120, springConstant: 0.08,
        damping: 0.95, avoidOverlap: 0.5,
      };
    }
  }

  function _forceAtlas2Params(n) {
    switch (_tierForSize(n)) {
      case "small":  return {
        gravitationalConstant: -80, centralGravity: 0.008,
        springLength: 220, springConstant: 0.08,
        damping: 0.6, avoidOverlap: 1.0,
      };
      case "medium": return {
        gravitationalConstant: -50, centralGravity: 0.02,
        springLength: 180, springConstant: 0.08,
        damping: 0.75, avoidOverlap: 0.9,
      };
      case "large":  return {
        gravitationalConstant: -30, centralGravity: 0.05,
        springLength: 140, springConstant: 0.10,
        damping: 0.85, avoidOverlap: 0.7,
      };
      case "huge":   return {
        gravitationalConstant: -15, centralGravity: 0.12,
        springLength: 100, springConstant: 0.15,
        damping: 0.95, avoidOverlap: 0.5,
      };
    }
  }

  function _stabilizationIterations(n) {
    // More iterations for bigger graphs, but cap at something reasonable
    // so the user never waits more than a few seconds.
    if (n <= 60)   return 1500;
    if (n <= 200)  return 2000;
    if (n <= 600)  return 1200;
    return 800;  // huge — we'd rather stop early than hang forever
  }

  // Hard safety cap: if stabilization doesn't fire its "done" event
  // within this many milliseconds we force physics off anyway. Prevents
  // a runaway simulation from looping forever on pathological inputs.
  const STABILIZATION_SAFETY_TIMEOUT_MS = 6000;

  // Upper bound on node velocity during physics runs. vis.js doesn't
  // actually expose `maxVelocity` as a first-class option (only
  // `minVelocity`), so this value is enforced via a `stabilizationProgress`
  // listener below that clamps runaway speeds.
  const HARD_MAX_VELOCITY = 50;

  function _nodeCount() {
    try { return nodes.length; } catch (e) { return 0; }
  }

  function _sugiyamaLayoutConfig(levelField) {
    // Adapt spacing to graph size so nodes don't overlap on crowded levels
    const n = _nodeCount();
    let nodeSpacing, treeSpacing, levelSeparation;
    if (n <= 20) {
      nodeSpacing = 220; treeSpacing = 280; levelSeparation = 220;
    } else if (n <= 60) {
      nodeSpacing = 180; treeSpacing = 240; levelSeparation = 200;
    } else if (n <= 150) {
      nodeSpacing = 140; treeSpacing = 200; levelSeparation = 180;
    } else {
      nodeSpacing = 100; treeSpacing = 160; levelSeparation = 160;
    }
    return {
      levelField: levelField,
      layout: {
        hierarchical: {
          enabled: true, direction: "UD", sortMethod: "directed",
          shakeTowards: "leaves", levelSeparation: levelSeparation,
          nodeSpacing: nodeSpacing, treeSpacing: treeSpacing,
          blockShifting: true, edgeMinimization: true,
          parentCentralization: true,
        }
      },
      physics: { enabled: false },
    };
  }

  function layoutConfig(mode) {
    const n = _nodeCount();
    if (mode === "sugiyama-year")  return _sugiyamaLayoutConfig("year_level");
    if (mode === "sugiyama-depth") return _sugiyamaLayoutConfig("depth_level");
    if (mode === "force-directed") {
      return {
        levelField: null,
        layout: { hierarchical: { enabled: false } },
        physics: {
          enabled: true, solver: "barnesHut",
          barnesHut: _barnesHutParams(n),
          stabilization: {
            enabled: true,
            iterations: _stabilizationIterations(n),
            updateInterval: 50,
            fit: true,
          },
          minVelocity: 0.75,
          timestep: 0.3,
          adaptiveTimestep: true,
        },
      };
    }
    if (mode === "fruchterman") {
      return {
        levelField: null,
        layout: { hierarchical: { enabled: false } },
        physics: {
          enabled: true, solver: "forceAtlas2Based",
          forceAtlas2Based: _forceAtlas2Params(n),
          stabilization: {
            enabled: true,
            iterations: _stabilizationIterations(n),
            updateInterval: 50,
            fit: true,
          },
          minVelocity: 0.75,
          timestep: 0.3,
          adaptiveTimestep: true,
        },
      };
    }
    return null;
  }

  function applySpread(newMultiplier) {
    // Scale every node's position from the current centroid, so the graph
    // stretches or compresses around its middle without losing its shape.
    if (typeof network === 'undefined' || !network) return;
    const positions = network.getPositions();
    const ids = Object.keys(positions);
    if (!ids.length) return;
    let cx = 0, cy = 0;
    for (const id of ids) { cx += positions[id].x; cy += positions[id].y; }
    cx /= ids.length; cy /= ids.length;
    const ratio = newMultiplier / currentSpread;
    currentSpread = newMultiplier;
    const updates = [];
    for (const id of ids) {
      updates.push({
        id: id,
        x: cx + (positions[id].x - cx) * ratio,
        y: cy + (positions[id].y - cy) * ratio,
      });
    }
    nodes.update(updates);
    network.fit();
  }

  function resetSpreadSlider() {
    currentSpread = 1.0;
    const slider = document.getElementById('citracer-spread');
    if (slider) slider.value = '1';
  }

  let _safetyTimer = null;

  function switchLayout(mode) {
    const cfg = layoutConfig(mode);
    if (!cfg) return;
    currentLayout = mode;
    resetSpreadSlider();

    if (_safetyTimer) { clearTimeout(_safetyTimer); _safetyTimer = null; }

    if (cfg.levelField) {
      const updates = [];
      nodes.forEach(n => {
        const d = NODE_DETAILS[n.id];
        if (d && d[cfg.levelField] !== undefined) {
          updates.push({ id: n.id, level: d[cfg.levelField] });
        }
      });
      if (updates.length) nodes.update(updates);
    }

    network.setOptions({ layout: cfg.layout, physics: cfg.physics });

    if (mode.startsWith("sugiyama")) {
      setTimeout(() => {
        network.setOptions({ layout: { hierarchical: { enabled: false } } });
        // Fix overlapping nodes: vis.js sometimes stacks nodes at the
        // exact same position when multiple nodes share a level. Detect
        // collisions and spread them apart horizontally.
        const positions = network.getPositions();
        const byPos = {};
        for (const id in positions) {
          const p = positions[id];
          const key = Math.round(p.x) + ',' + Math.round(p.y);
          if (!byPos[key]) byPos[key] = [];
          byPos[key].push(id);
        }
        const fixUpdates = [];
        for (const key in byPos) {
          const group = byPos[key];
          if (group.length <= 1) continue;
          const p = positions[group[0]];
          const spacing = 120;
          const startX = p.x - (group.length - 1) * spacing / 2;
          group.forEach((id, i) => {
            fixUpdates.push({ id: id, x: startX + i * spacing, y: p.y });
          });
        }
        if (fixUpdates.length) nodes.update(fixUpdates);
        applyCurvedEdges();
        network.fit();
      }, 120);
    } else {
      network.once("stabilizationIterationsDone", () => {
        network.setOptions({ physics: { enabled: false } });
        if (_safetyTimer) { clearTimeout(_safetyTimer); _safetyTimer = null; }
        applyCurvedEdges();
        network.fit();
      });

      _safetyTimer = setTimeout(() => {
        network.setOptions({ physics: { enabled: false } });
        applyCurvedEdges();
        network.fit();
      }, STABILIZATION_SAFETY_TIMEOUT_MS);
    }
  }

  function showInfo(nodeId) {
    const d = NODE_DETAILS[nodeId];
    if (!d) return;
    const authors = (d.authors || []).slice(0, 8).join(', ')
                  + ((d.authors || []).length > 8 ? ', et al.' : '');
    let html = '<h3>' + escapeHtml(d.title) + '</h3>';
    html += '<div class="meta">';
    if (authors) html += escapeHtml(authors) + '<br>';
    if (d.publication_date) html += 'Published: ' + d.publication_date + ' &middot; ';
    else if (d.year) html += 'Year: ' + d.year + ' &middot; ';
    else html += 'Year: unknown &middot; ';
    if (d.citation_count != null) html += 'Citations: ' + d.citation_count + ' &middot; ';
    html += 'Status: <b>' + escapeHtml(d.status) + '</b>';
    if (d.is_new) html += ' <span style="background:#ff8c00;color:#fff;padding:1px 6px;border-radius:3px;font-size:11px;font-weight:bold;">NEW</span>';
    html += ' &middot; depth ' + d.depth;
    html += '</div>';
    // Per-node analytics
    const nm = (ANALYTICS.node_metrics || {})[nodeId];
    if (nm) {
      html += '<div class="meta" style="color:#666;">';
      html += 'PageRank: ' + nm.pagerank.toFixed(4) + ' &middot; ';
      html += 'Betweenness: ' + nm.betweenness.toFixed(4) + ' &middot; ';
      html += 'In: ' + nm.in_degree + ' &middot; Out: ' + nm.out_degree;
      if (nm.is_pivot) html += ' &middot; <b style="color:#d62728;">PIVOT</b>';
      html += '</div>';
    }
    if (d.url) {
      html += '<div><a href="' + escapeHtml(d.url) + '" target="_blank">open ↗</a></div>';
    }
    if (d.abstract) {
      const abstractExpanded = expandedAbstracts.has(nodeId);
      html += '<details class="abstract-block"'
            + (abstractExpanded ? ' open' : '')
            + ' data-node-id="' + escapeHtml(nodeId) + '">'
            + '<summary>abstract</summary>'
            + '<div class="abstract-body">' + escapeHtml(d.abstract) + '</div>'
            + '</details>';
    }
    if (d.keyword_hits && d.keyword_hits.length) {
      const expanded = expandedHits.has(nodeId);
      const hitTypes = d.keyword_hit_types || [];
      const nSemantic = hitTypes.filter(t => t === "semantic").length;
      const nRegex = d.keyword_hits.length - nSemantic;
      let hitsLabel = d.keyword_hits.length + ' keyword hit(s)';
      if (nSemantic > 0 && nRegex > 0) {
        hitsLabel += ' <span style="color:#888;font-weight:normal;">(' + nRegex + ' regex + ' + nSemantic + ' semantic)</span>';
      } else if (nSemantic > 0) {
        hitsLabel += ' <span style="color:#888;font-weight:normal;">(semantic)</span>';
      }
      const visibleCount = expanded ? d.keyword_hits.length : Math.min(5, d.keyword_hits.length);
      html += '<div class="hits"><b>' + hitsLabel + '</b>';
      const hitScores = d.keyword_hit_scores || [];
      for (let hi = 0; hi < visibleCount; hi++) {
        const isSem = hitTypes[hi] === "semantic";
        if (isSem) {
          const score = hitScores[hi] ? hitScores[hi].toFixed(2) : '?';
          html += '<div class="hit-snippet" style="border-left:3px solid #9c27b0;padding-left:8px;">'
                + '<span style="background:#9c27b0;color:#fff;padding:1px 5px;border-radius:3px;font-size:10px;font-weight:bold;">SEM ' + score + '</span> '
                + '<span style="color:#888;font-size:11px;">conceptual match</span>'
                + '<br>' + escapeHtml(d.keyword_hits[hi])
                + '</div>';
        } else {
          html += '<div class="hit-snippet">' + highlightKeyword(d.keyword_hits[hi]) + '</div>';
        }
      }
      if (d.keyword_hits.length > 5) {
        if (expanded) {
          html += '<div class="hits-toggle" data-node-id="'
                + escapeHtml(nodeId) + '" data-action="collapse">show fewer</div>';
        } else {
          html += '<div class="hits-toggle" data-node-id="'
                + escapeHtml(nodeId) + '" data-action="expand">show '
                + (d.keyword_hits.length - 5) + ' more</div>';
        }
      }
      html += '</div>';
    }
    currentNodeId = nodeId;
    const body = document.getElementById('citracer-info-body');
    body.innerHTML = html;
    document.getElementById('citracer-info').style.display = 'block';
    renderMath(body);
  }

  // Event delegation for the show-more / show-fewer toggle
  document.getElementById('citracer-info-body').addEventListener('click', (ev) => {
    const t = ev.target.closest('.hits-toggle');
    if (!t) return;
    const id = t.getAttribute('data-node-id');
    if (t.getAttribute('data-action') === 'expand') {
      expandedHits.add(id);
    } else {
      expandedHits.delete(id);
    }
    showInfo(id);
  });

  // Event delegation for the abstract <details> — remember its open state
  // so hover re-renders don't collapse it.
  document.getElementById('citracer-info-body').addEventListener('toggle', (ev) => {
    const det = ev.target;
    if (!det || det.tagName !== 'DETAILS' || !det.classList.contains('abstract-block')) return;
    const id = det.getAttribute('data-node-id');
    if (!id) return;
    if (det.open) expandedAbstracts.add(id);
    else expandedAbstracts.delete(id);
  }, true);  // useCapture=true because `toggle` doesn't bubble

  document.querySelectorAll('.legend-item').forEach(el => {
    el.addEventListener('click', () => {
      const status = el.getAttribute('data-status');
      if (disabledStatus.has(status)) {
        disabledStatus.delete(status);
        el.classList.remove('disabled');
      } else {
        disabledStatus.add(status);
        el.classList.add('disabled');
      }
      applyFilter();
      saveState();
    });
  });

  document.querySelectorAll('.legend-edge-toggle').forEach(el => {
    el.addEventListener('click', () => {
      const t = el.getAttribute('data-edge-type');
      if (disabledEdgeTypes.has(t)) {
        disabledEdgeTypes.delete(t);
        el.classList.remove('disabled');
      } else {
        disabledEdgeTypes.add(t);
        el.classList.add('disabled');
      }
      applyFilter();
      saveState();
    });
  });

  // Layout dropdown
  const layoutSelect = document.getElementById('citracer-layout');
  if (layoutSelect) {
    layoutSelect.value = DEFAULT_LAYOUT;
    layoutSelect.addEventListener('change', (ev) => {
      switchLayout(ev.target.value);
      saveState();
    });
  }

  // Size mode dropdown
  const sizeSelect = document.getElementById('citracer-size');
  if (sizeSelect) {
    sizeSelect.addEventListener('change', (ev) => {
      currentSizeMode = ev.target.value;
      applyFilter();  // triggers a size recomputation
      saveState();
    });
  }

  // Curved edges checkbox
  const curvedCheckbox = document.getElementById('citracer-curved');
  if (curvedCheckbox) {
    curvedCheckbox.addEventListener('change', (ev) => {
      curvedEdges = ev.target.checked;
      applyCurvedEdges();
      saveState();
    });
  }

  // Spread slider: rescales node positions around the centroid. Using
  // 'input' makes it live during the drag.
  const spreadSlider = document.getElementById('citracer-spread');
  if (spreadSlider) {
    spreadSlider.addEventListener('input', (ev) => {
      applySpread(parseFloat(ev.target.value));
      saveState();
    });
  }

  // Export PNG — renders the graph to a large offscreen canvas manually
  // (vis.js canvas scaling is unreliable for export, so we draw nodes/edges
  // ourselves using the same position/color/size data as the SVG exporter)
  const exportBtn = document.getElementById('citracer-export-png');
  if (exportBtn) {
    exportBtn.addEventListener('click', () => {
      if (typeof network === 'undefined' || !network) return;
      const scale = parseInt(document.getElementById('citracer-export-scale').value) || 3;
      exportBtn.textContent = 'Rendering...';
      exportBtn.disabled = true;

      network.fit();
      setTimeout(() => {
        try {
          const positions = network.getPositions();
          const allNodeIds = Object.keys(positions);
          if (!allNodeIds.length) { exportBtn.textContent = 'PNG'; exportBtn.disabled = false; return; }

          // Bounding box
          let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
          allNodeIds.forEach(id => {
            const p = positions[id];
            if (p.x < minX) minX = p.x;
            if (p.y < minY) minY = p.y;
            if (p.x > maxX) maxX = p.x;
            if (p.y > maxY) maxY = p.y;
          });
          const pad = 120;
          minX -= pad; minY -= pad; maxX += pad; maxY += pad;
          const w = maxX - minX;
          const h = maxY - minY;

          const canvas = document.createElement('canvas');
          canvas.width = w * scale;
          canvas.height = h * scale;
          const ctx = canvas.getContext('2d');
          ctx.scale(scale, scale);
          ctx.translate(-minX, -minY);

          // White background
          ctx.fillStyle = '#ffffff';
          ctx.fillRect(minX, minY, w, h);

          const colors = {
            root: '#1f77b4', analyzed: '#2ca02c', no_match: '#9e9e9e',
            unavailable: '#d62728', pending: '#cccccc', new: '#ff8c00',
          };

          // Draw edges
          edges.forEach(e => {
            if (e.hidden) return;
            const from = positions[e.from];
            const to = positions[e.to];
            if (!from || !to) return;
            const isSec = edgeType(e) === 'secondary';

            const dx = to.x - from.x, dy = to.y - from.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 1) return;
            const toNode = nodes.get(e.to);
            const r = (toNode && toNode.size) || 20;
            const ratio = Math.max(0, (dist - r - 6) / dist);
            const tx = from.x + dx * ratio, ty = from.y + dy * ratio;

            ctx.save();
            ctx.strokeStyle = isSec ? '#5c87b5' : '#444444';
            ctx.lineWidth = isSec ? 1.5 : 2.5;
            ctx.globalAlpha = isSec ? 0.75 : 0.9;
            if (isSec) ctx.setLineDash([6, 6]);

            if (curvedEdges) {
              const mx = (from.x + tx) / 2, my = (from.y + ty) / 2;
              const nx = -(ty - from.y), ny = tx - from.x;
              const nl = Math.sqrt(nx * nx + ny * ny) || 1;
              const curve = isSec ? 0.15 : 0.10;
              const cpx = mx + nx / nl * dist * curve;
              const cpy = my + ny / nl * dist * curve;
              ctx.beginPath();
              ctx.moveTo(from.x, from.y);
              ctx.quadraticCurveTo(cpx, cpy, tx, ty);
              ctx.stroke();
            } else {
              ctx.beginPath();
              ctx.moveTo(from.x, from.y);
              ctx.lineTo(tx, ty);
              ctx.stroke();
            }

            // Arrowhead
            const angle = Math.atan2(ty - from.y, tx - from.x);
            const aLen = 10;
            ctx.setLineDash([]);
            ctx.fillStyle = ctx.strokeStyle;
            ctx.beginPath();
            ctx.moveTo(tx, ty);
            ctx.lineTo(tx - aLen * Math.cos(angle - 0.35), ty - aLen * Math.sin(angle - 0.35));
            ctx.lineTo(tx - aLen * Math.cos(angle + 0.35), ty - aLen * Math.sin(angle + 0.35));
            ctx.closePath();
            ctx.fill();
            ctx.restore();
          });

          // Draw nodes
          allNodeIds.forEach(id => {
            const n = nodes.get(id);
            if (!n || n.hidden) return;
            const p = positions[id];
            const d = NODE_DETAILS[id] || {};
            const effectiveStatus = d.is_new ? 'new' : (d.status || 'pending');
            const fill = colors[effectiveStatus] || colors.pending;
            const r = n.size || 20;

            ctx.save();
            ctx.globalAlpha = 0.9;
            ctx.fillStyle = fill;
            ctx.beginPath();
            ctx.arc(p.x, p.y, r, 0, Math.PI * 2);
            ctx.fill();
            if (effectiveStatus === 'root') {
              ctx.lineWidth = 3;
              ctx.strokeStyle = '#0b3d61';
              ctx.stroke();
            }
            ctx.restore();

            // Full label
            const title = d.title || n.label || '';
            const year = d.year ? String(d.year) : '';
            const label = title + (year ? ' (' + year + ')' : '');
            if (label) {
              ctx.save();
              ctx.font = '11px system-ui, sans-serif';
              ctx.fillStyle = '#222222';
              ctx.textAlign = 'center';
              ctx.textBaseline = 'top';
              ctx.fillText(label, p.x, p.y + r + 4);
              ctx.restore();
            }
          });

          // Download
          canvas.toBlob((blob) => {
            const a = document.createElement('a');
            a.download = 'citracer-graph.png';
            a.href = URL.createObjectURL(blob);
            a.click();
            URL.revokeObjectURL(a.href);
            exportBtn.textContent = 'PNG';
            exportBtn.disabled = false;
          }, 'image/png');
        } catch (e) {
          console.error('PNG export failed:', e);
          exportBtn.textContent = 'PNG';
          exportBtn.disabled = false;
          alert('PNG export failed. See console for details.');
        }
      }, 600);
    });
  }

  // Export SVG — builds a vector graphic from the vis.js node/edge data
  const svgBtn = document.getElementById('citracer-export-svg');
  if (svgBtn) {
    svgBtn.addEventListener('click', () => {
      if (typeof network === 'undefined' || !network) return;
      svgBtn.textContent = 'Rendering...';
      svgBtn.disabled = true;

      try {
        const positions = network.getPositions();
        const allNodeIds = Object.keys(positions);
        if (!allNodeIds.length) { svgBtn.textContent = 'SVG'; svgBtn.disabled = false; return; }

        // Compute bounding box
        let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
        allNodeIds.forEach(id => {
          const p = positions[id];
          if (p.x < minX) minX = p.x;
          if (p.y < minY) minY = p.y;
          if (p.x > maxX) maxX = p.x;
          if (p.y > maxY) maxY = p.y;
        });
        const pad = 150;  // enough for full-length labels
        minX -= pad; minY -= pad; maxX += pad; maxY += pad;
        const w = maxX - minX;
        const h = maxY - minY;

        // Status colors (same as Python STATUS_COLORS)
        const colors = {
          root: '#1f77b4', analyzed: '#2ca02c', no_match: '#9e9e9e',
          unavailable: '#d62728', pending: '#cccccc', new: '#ff8c00',
        };

        let svg = '<?xml version="1.0" encoding="UTF-8"?>\n';
        svg += '<svg xmlns="http://www.w3.org/2000/svg" width="' + w + '" height="' + h + '" viewBox="' + minX + ' ' + minY + ' ' + w + ' ' + h + '">\n';
        svg += '<rect x="' + minX + '" y="' + minY + '" width="' + w + '" height="' + h + '" fill="white"/>\n';

        // Arrowhead marker
        svg += '<defs><marker id="arrow" viewBox="0 0 10 6" refX="10" refY="3" markerWidth="8" markerHeight="6" orient="auto"><path d="M0,0 L10,3 L0,6 Z" fill="#444"/></marker>';
        svg += '<marker id="arrow-sec" viewBox="0 0 10 6" refX="10" refY="3" markerWidth="8" markerHeight="6" orient="auto"><path d="M0,0 L10,3 L0,6 Z" fill="#5c87b5"/></marker></defs>\n';

        // Draw edges (curved or straight, matching the current UI toggle)
        edges.forEach(e => {
          if (e.hidden) return;
          const from = positions[e.from];
          const to = positions[e.to];
          if (!from || !to) return;
          const isSec = edgeType(e) === 'secondary';
          const stroke = isSec ? '#5c87b5' : '#444444';
          const strokeW = isSec ? 1.5 : 2.5;
          const opacity = isSec ? 0.75 : 0.9;
          const dash = isSec ? ' stroke-dasharray="6,6"' : '';
          const marker = isSec ? 'url(#arrow-sec)' : 'url(#arrow)';

          // Shorten endpoint so arrowhead doesn't overlap the node circle
          const dx = to.x - from.x, dy = to.y - from.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 1) return;
          const toNode = nodes.get(e.to);
          const r = (toNode && toNode.size) || 20;
          const ratio = Math.max(0, (dist - r - 2) / dist);
          const tx = from.x + dx * ratio, ty = from.y + dy * ratio;

          if (curvedEdges) {
            // Quadratic Bézier: control point perpendicular to the midpoint
            const mx = (from.x + tx) / 2, my = (from.y + ty) / 2;
            const nx = -(ty - from.y), ny = tx - from.x;
            const nl = Math.sqrt(nx * nx + ny * ny) || 1;
            const curve = isSec ? 0.15 : 0.10;
            const cx = mx + nx / nl * dist * curve;
            const cy = my + ny / nl * dist * curve;
            svg += '<path d="M' + from.x.toFixed(1) + ',' + from.y.toFixed(1)
                  + ' Q' + cx.toFixed(1) + ',' + cy.toFixed(1)
                  + ' ' + tx.toFixed(1) + ',' + ty.toFixed(1)
                  + '" fill="none" stroke="' + stroke + '" stroke-width="' + strokeW + '" opacity="' + opacity + '"' + dash + ' marker-end="' + marker + '"/>\n';
          } else {
            svg += '<line x1="' + from.x.toFixed(1) + '" y1="' + from.y.toFixed(1) + '" x2="' + tx.toFixed(1) + '" y2="' + ty.toFixed(1) + '" stroke="' + stroke + '" stroke-width="' + strokeW + '" opacity="' + opacity + '"' + dash + ' marker-end="' + marker + '"/>\n';
          }
        });

        // Draw nodes with full titles (not the truncated vis.js label)
        allNodeIds.forEach(id => {
          const n = nodes.get(id);
          if (!n || n.hidden) return;
          const p = positions[id];
          const d = NODE_DETAILS[id] || {};
          const effectiveStatus = d.is_new ? 'new' : (d.status || 'pending');
          const fill = colors[effectiveStatus] || colors.pending;
          const r = n.size || 20;
          const borderW = effectiveStatus === 'root' ? 3 : 1;

          svg += '<circle cx="' + p.x.toFixed(1) + '" cy="' + p.y.toFixed(1) + '" r="' + r + '" fill="' + fill + '" stroke="' + fill + '" stroke-width="' + borderW + '" opacity="0.9"/>\n';

          // Full title + year from node details (not the truncated vis.js label)
          const title = d.title || n.label || '';
          const year = d.publication_date || (d.year ? String(d.year) : '');
          const fullLabel = title + (year ? ' (' + year + ')' : '');
          if (fullLabel) {
            const escaped = fullLabel.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
            svg += '<text x="' + p.x.toFixed(1) + '" y="' + (p.y + r + 14).toFixed(1) + '" text-anchor="middle" font-family="system-ui, sans-serif" font-size="11" fill="#222">' + escaped + '</text>\n';
          }
        });

        svg += '</svg>';

        // Download
        const blob = new Blob([svg], { type: 'image/svg+xml;charset=utf-8' });
        const a = document.createElement('a');
        a.download = 'citracer-graph.svg';
        a.href = URL.createObjectURL(blob);
        a.click();
        URL.revokeObjectURL(a.href);
      } catch (e) {
        console.error('SVG export failed:', e);
        alert('SVG export failed. See console for details.');
      }
      svgBtn.textContent = 'SVG';
      svgBtn.disabled = false;
    });
  }

  // Legend panel resize via right-edge drag
  const resizeHandle = document.getElementById('citracer-legend-resize');
  const legendPanel = document.getElementById('citracer-legend');
  if (resizeHandle && legendPanel) {
    // Position the fixed handle at the right edge of the panel
    function syncHandle() {
      const rect = legendPanel.getBoundingClientRect();
      resizeHandle.style.left = (rect.right - 4) + 'px';
    }
    syncHandle();

    let dragging = false;
    resizeHandle.addEventListener('mousedown', (ev) => {
      ev.preventDefault();
      dragging = true;
      resizeHandle.classList.add('active');
      document.body.style.cursor = 'col-resize';
      document.body.style.userSelect = 'none';
    });
    document.addEventListener('mousemove', (ev) => {
      if (!dragging) return;
      const rect = legendPanel.getBoundingClientRect();
      const newWidth = Math.max(200, Math.min(ev.clientX - rect.left, window.innerWidth * 0.5));
      legendPanel.style.width = newWidth + 'px';
      syncHandle();
    });
    document.addEventListener('mouseup', () => {
      if (!dragging) return;
      dragging = false;
      resizeHandle.classList.remove('active');
      document.body.style.cursor = '';
      document.body.style.userSelect = '';
    });
    window.addEventListener('resize', syncHandle);
  }

  // Reset button — clears saved state and reloads the page to start fresh
  const resetBtn = document.getElementById('citracer-reset');
  if (resetBtn) {
    resetBtn.addEventListener('click', () => {
      if (confirm('Clear saved layout, filters and node positions?')) {
        clearState();
        location.reload();
      }
    });
  }

  // --- analytics panel --------------------------------------------------
  (function populateAnalytics() {
    const body = document.getElementById('citracer-analytics-body');
    if (!body || !ANALYTICS.global) return;
    const g = ANALYTICS.global;
    let h = '';
    h += '<div>Density: ' + g.density.toFixed(4) + '</div>';
    h += '<div>Avg degree: ' + g.avg_degree.toFixed(2) + '</div>';
    h += '<div>Components: ' + g.connected_components + '</div>';
    // Pivot papers
    const pivots = ANALYTICS.pivot_papers || [];
    if (pivots.length) {
      h += '<div style="margin-top:6px;font-weight:bold;">Pivot papers (' + pivots.length + ')</div>';
      pivots.forEach(function(pid) {
        const d = NODE_DETAILS[pid];
        if (!d) { h += '<div>' + escapeHtml(pid) + '</div>'; return; }
        const authors = (d.authors && d.authors.length) ? d.authors[0].split(' ').pop() + (d.authors.length > 1 ? ' et al.' : '') : '';
        const title = d.title || '';
        const label = (authors ? authors + ' - ' : '') + title + (d.year ? ' (' + d.year + ')' : '');
        h += '<div class="citracer-pivot-link" data-node-id="' + escapeHtml(pid) + '" '
           + 'style="cursor:pointer;color:#1f77b4;text-decoration:underline;margin:2px 0;'
           + 'overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:block;" '
           + 'title="' + escapeHtml(label) + '">'
           + escapeHtml(label) + '</div>';
      });
    }
    // Timeline
    const tl = ANALYTICS.timeline || [];
    if (tl.length) {
      h += '<div style="margin-top:6px;font-weight:bold;">Keyword density by year</div>';
      h += '<table style="font-size:10px;width:100%;border-collapse:collapse;">';
      h += '<tr><th>Year</th><th>Total</th><th>w/ kw</th><th>Density</th></tr>';
      tl.forEach(function(t) {
        const pct = (t.keyword_density * 100).toFixed(0) + '%';
        const bar = '<span style="display:inline-block;width:' + Math.round(t.keyword_density * 50)
                   + 'px;height:8px;background:#2ca02c;vertical-align:middle;"></span>';
        h += '<tr><td>' + t.year + '</td><td>' + t.total + '</td><td>' + t.with_keyword
           + '</td><td>' + pct + ' ' + bar + '</td></tr>';
      });
      h += '</table>';
    }
    body.innerHTML = h;
    // Click on pivot paper -> focus node
    body.querySelectorAll('.citracer-pivot-link').forEach(function(el) {
      el.addEventListener('click', function() {
        const nid = this.getAttribute('data-node-id');
        if (network) {
          network.focus(nid, { scale: 1.2, animation: true });
          network.selectNodes([nid]);
          showInfo(nid);
        }
      });
    });
  })();

  // --- search box ------------------------------------------------------
  function runSearch(query) {
    const results = document.getElementById('citracer-search-results');
    if (!results) return;
    results.innerHTML = '';
    if (!query || query.length < 2) return;
    const q = query.toLowerCase();
    const matches = [];
    for (const id in NODE_DETAILS) {
      const d = NODE_DETAILS[id];
      const title = (d.title || '').toLowerCase();
      const authors = (d.authors || []).join(' ').toLowerCase();
      let score = 0;
      if (title.includes(q)) score += 10;
      if (authors.includes(q)) score += 5;
      if (score > 0) matches.push({ id: id, score: score, d: d });
    }
    matches.sort((a, b) => b.score - a.score);
    matches.slice(0, 8).forEach(m => {
      const div = document.createElement('div');
      div.className = 'result';
      const shortTitle = (m.d.title || '').slice(0, 70)
                      + ((m.d.title || '').length > 70 ? '…' : '');
      const firstAuthor = (m.d.authors || [])[0] || '';
      div.innerHTML = '<div class="result-title">' + escapeHtml(shortTitle) + '</div>'
                    + '<div class="result-meta">'
                    + escapeHtml(firstAuthor)
                    + (m.d.year ? ' · ' + m.d.year : '')
                    + '</div>';
      div.addEventListener('click', () => {
        if (typeof network !== 'undefined' && network) {
          network.focus(m.id, {
            scale: 1.3,
            animation: { duration: 400, easingFunction: 'easeInOutQuad' },
          });
          network.selectNodes([m.id]);
          showInfo(m.id);
          setPinned(m.id);
        }
      });
      results.appendChild(div);
    });
  }
  const searchBox = document.getElementById('citracer-search');
  if (searchBox) {
    let debounce = null;
    searchBox.addEventListener('input', (ev) => {
      clearTimeout(debounce);
      debounce = setTimeout(() => runSearch(ev.target.value), 120);
    });
    // Enter → focus the first result
    searchBox.addEventListener('keydown', (ev) => {
      if (ev.key === 'Enter') {
        const first = document.querySelector('.citracer-search-results .result');
        if (first) first.click();
      }
    });
  }

  // Cache of original (borderWidth, color) pairs so we can restore a node's
  // look when it gets unpinned.
  const pinRestore = new Map();

  function setPinned(nodeId) {
    // Restore the previously pinned node, if any.
    if (pinnedNodeId && pinnedNodeId !== nodeId) {
      const saved = pinRestore.get(pinnedNodeId);
      if (saved) {
        nodes.update({
          id: pinnedNodeId,
          borderWidth: saved.borderWidth,
          color: saved.color,
        });
        pinRestore.delete(pinnedNodeId);
      }
    }
    pinnedNodeId = nodeId;
    const panel = document.getElementById('citracer-info');
    if (nodeId) {
      // Cache the current look and apply the pinned look.
      const n = nodes.get(nodeId);
      if (n && !pinRestore.has(nodeId)) {
        pinRestore.set(nodeId, {
          borderWidth: n.borderWidth || 1,
          color: n.color,
        });
      }
      const baseBg = (n && n.color && n.color.background) || '#ffffff';
      nodes.update({
        id: nodeId,
        borderWidth: 5,
        color: {
          background: baseBg,
          border: '#06c',
          highlight: { background: baseBg, border: '#06c' },
          hover: { background: baseBg, border: '#06c' },
        },
      });
      panel.classList.add('pinned');
    } else {
      panel.classList.remove('pinned');
    }
  }

  // --- context menu --------------------------------------------------
  let contextMenuNodeId = null;

  function openContextMenu(nodeId, clientX, clientY) {
    contextMenuNodeId = nodeId;
    const menu = document.getElementById('citracer-context-menu');
    if (!menu) return;
    const d = NODE_DETAILS[nodeId] || {};
    // Toggle the "Open link" row — hide it when there's no URL
    const openItem = menu.querySelector('[data-action="open"]');
    if (openItem) openItem.style.display = d.url ? '' : 'none';
    // Toggle "Supply PDF" — only for unavailable nodes
    const supplyItem = menu.querySelector('[data-action="supply"]');
    if (supplyItem) supplyItem.style.display = d.status === 'unavailable' ? '' : 'none';
    // Toggle Pin label
    const pinItem = menu.querySelector('[data-action="pin"]');
    if (pinItem) pinItem.textContent = (pinnedNodeId === nodeId) ? 'Unpin' : 'Pin';
    menu.style.display = 'block';
    // Clamp to viewport
    const menuRect = menu.getBoundingClientRect();
    const maxX = window.innerWidth - menuRect.width - 6;
    const maxY = window.innerHeight - menuRect.height - 6;
    menu.style.left = Math.min(clientX, maxX) + 'px';
    menu.style.top  = Math.min(clientY, maxY) + 'px';
  }

  function closeContextMenu() {
    const menu = document.getElementById('citracer-context-menu');
    if (menu) menu.style.display = 'none';
    contextMenuNodeId = null;
  }

  document.getElementById('citracer-context-menu').addEventListener('click', (ev) => {
    const item = ev.target.closest('.ctx-item');
    if (!item || !contextMenuNodeId) return;
    const action = item.getAttribute('data-action');
    const nodeId = contextMenuNodeId;
    const d = NODE_DETAILS[nodeId] || {};
    if (action === 'hide') {
      manuallyHidden.add(nodeId);
      if (pinnedNodeId === nodeId) {
        setPinned(null);
        document.getElementById('citracer-info').style.display = 'none';
      }
      applyFilter();
      saveState();
    } else if (action === 'pin') {
      if (pinnedNodeId === nodeId) {
        setPinned(null);
      } else {
        showInfo(nodeId);
        setPinned(nodeId);
      }
      saveState();
    } else if (action === 'open') {
      if (d.url) window.open(d.url, '_blank');
    } else if (action === 'supply') {
      const input = prompt(
        'Enter a local path or URL to the PDF for:\n'
        + (d.title || nodeId) + '\n\n'
        + 'Example: ~/papers/paper.pdf or https://example.com/paper.pdf'
      );
      if (input && input.trim()) {
        _supplyPdfEntries.push({ id: nodeId, path: input.trim() });
        _updateSupplyBanner();
      }
    }
    closeContextMenu();
  });

  // --- Supply PDF banner ---
  const _supplyPdfEntries = [];

  function _updateSupplyBanner() {
    const banner = document.getElementById('citracer-supply-banner');
    const cmd = document.getElementById('citracer-supply-cmd');
    if (!banner || !cmd || !_supplyPdfEntries.length) return;
    const parts = _supplyPdfEntries.map(e =>
      '--supply-pdf "' + e.id + '=' + e.path + '"'
    );
    cmd.textContent = parts.join(' \\\n  ');
    banner.style.display = 'block';
  }

  // Click to copy
  const supplyCmd = document.getElementById('citracer-supply-cmd');
  if (supplyCmd) {
    supplyCmd.addEventListener('click', () => {
      const text = supplyCmd.textContent;
      navigator.clipboard.writeText(text).then(() => {
        const orig = supplyCmd.style.outline;
        supplyCmd.style.outline = '2px solid #6cf';
        setTimeout(() => { supplyCmd.style.outline = orig; }, 600);
      });
    });
  }

  // Dismiss banner
  const supplyClose = document.getElementById('citracer-supply-close');
  if (supplyClose) {
    supplyClose.addEventListener('click', () => {
      document.getElementById('citracer-supply-banner').style.display = 'none';
    });
  }

  // Dismiss context menu on any outside click or Escape
  document.addEventListener('click', (ev) => {
    const menu = document.getElementById('citracer-context-menu');
    if (menu && !menu.contains(ev.target)) closeContextMenu();
  });
  document.addEventListener('keydown', (ev) => {
    if (ev.key === 'Escape') closeContextMenu();
  });

  // "show N manually hidden" banner → restore all
  const hiddenBanner = document.getElementById('citracer-hidden-banner');
  if (hiddenBanner) {
    hiddenBanner.addEventListener('click', () => {
      manuallyHidden.clear();
      applyFilter();
      saveState();
    });
  }

  // Info panel close button (×) — unpins and hides the panel
  const infoClose = document.getElementById('citracer-info-close');
  if (infoClose) {
    infoClose.addEventListener('click', (ev) => {
      ev.stopPropagation();
      setPinned(null);
      currentNodeId = null;
      document.getElementById('citracer-info').style.display = 'none';
      saveState();
    });
  }

  // Wait for the network to be created by pyvis, then wire events.
  function tryAttach() {
    if (typeof network !== 'undefined' && network) {
      const saved = loadState();
      if (saved) {
        // Non-position state first, so applyFilter() sees correct toggles
        applyLoadedState(saved);
        stateLoaded = true;
      }

      // If we have saved positions, bypass the Sugiyama layout entirely
      // and snap nodes back where the user left them. Otherwise run the
      // normal "let hierarchical lay it out, then release" dance.
      if (saved && saved.positions && Object.keys(saved.positions).length) {
        network.setOptions({
          layout: { hierarchical: { enabled: false } },
          physics: { enabled: false },
        });
        const moveUpdates = [];
        for (const id in saved.positions) {
          const p = saved.positions[id];
          if (p && typeof p.x === 'number' && typeof p.y === 'number') {
            moveUpdates.push({ id: id, x: p.x, y: p.y });
          }
        }
        if (moveUpdates.length) nodes.update(moveUpdates);
        setTimeout(() => network.fit(), 0);
        const reset = document.getElementById('citracer-reset');
        if (reset) reset.classList.add('saved');
      } else {
        switchLayout(currentLayout);
      }

      // Enforce edge smooth/straight setting (especially important when
      // restoring state where the user had straight edges enabled).
      applyCurvedEdges();

      // Live update on hover (ignored while pinned)
      network.on('hoverNode', params => {
        if (pinnedNodeId) return;
        showInfo(params.node);
      });
      // Click on a node: pin it (or unpin if already pinned). A click on
      // the empty canvas is deliberately a no-op — the pin survives until
      // the user either clicks the pinned node again, presses the X on
      // the info panel, or picks Unpin from the right-click menu.
      network.on('click', params => {
        closeContextMenu();
        if (!(params.nodes && params.nodes.length)) return;
        const id = params.nodes[0];
        if (pinnedNodeId === id) {
          setPinned(null);
          currentNodeId = null;
          document.getElementById('citracer-info').style.display = 'none';
        } else {
          showInfo(id);
          setPinned(id);
        }
        saveState();
      });

      // Right-click on a node = context menu
      network.on('oncontext', params => {
        // Always suppress the browser's native menu on the canvas
        if (params.event) params.event.preventDefault();
        const clicked = network.getNodeAt(params.pointer.DOM);
        if (clicked) {
          openContextMenu(clicked, params.event.clientX, params.event.clientY);
        } else {
          closeContextMenu();
        }
      });

      // Persist positions after the user finishes dragging a node
      network.on('dragEnd', () => saveState());

      applyFilter();

      // Re-apply pinned state AFTER applyFilter (which resizes nodes, which
      // can reset the border style we use for the pin indicator)
      if (saved && saved.pinned && NODE_DETAILS[saved.pinned]) {
        showInfo(saved.pinned);
        setPinned(saved.pinned);
      }
      return true;
    }
    return false;
  }
  if (!tryAttach()) {
    const t = setInterval(() => { if (tryAttach()) clearInterval(t); }, 200);
  }

  // Ctrl+Z / Ctrl+Y (or Ctrl+Shift+Z) for undo/redo
  document.addEventListener('keydown', (ev) => {
    // Don't intercept when typing in an input/textarea
    if (ev.target.tagName === 'INPUT' || ev.target.tagName === 'TEXTAREA') return;
    if (ev.ctrlKey || ev.metaKey) {
      if (ev.key === 'z' && !ev.shiftKey) {
        ev.preventDefault();
        undo();
      } else if (ev.key === 'y' || (ev.key === 'z' && ev.shiftKey)) {
        ev.preventDefault();
        redo();
      }
    }
  });
})();
</script>
