    padding: 12px 16px; border-radius: 8px; font-family: sans-serif;
    font-size: 13px; border: 1px solid #ccc;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08); z-index: 9999;
  }
  #citracer-legend { top: 10px; left: 10px; width: 280px; min-width: 200px; max-width: 50vw; max-height: calc(100vh - 30px); overflow-y: auto; overflow-x: hidden; }
  #citracer-legend-resize {
    position: fixed; top: 10px; width: 8px; height: calc(100vh - 30px);
    cursor: col-resize; z-index: 10001;
    pointer-events: auto;
  }
  #citracer-legend-resize:hover, #citracer-legend-resize.active {
    background: rgba(0,102,204,0.3); border-radius: 4px;
  }
  #citracer-info   { top: 10px; right: 10px; width: 380px;
                     max-height: calc(100vh - 30px); overflow-y: auto;
                     display: none; }
