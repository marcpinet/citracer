    cursor: pointer; user-select: none; padding: 2px 4px; border-radius: 4px;
    display: flex; align-items: center; gap: 8px;
  }
  .legend-item:hover { background: #f0f0f0; }
  .legend-item.disabled { opacity: 0.35; text-decoration: line-through; }
  .legend-dot {
    display: inline-block; width: 10px; height: 10px; border-radius: 50%;
  }
  .legend-edge { display: flex; align-items: center; gap: 8px; padding: 2px 4px; border-radius: 4px; }
  .legend-edge-toggle { cursor: pointer; user-select: none; }
  .legend-edge-toggle:hover { background: #f0f0f0; }
  .legend-edge-toggle.disabled { opacity: 0.4; }
  .edge-solid, .edge-dashed {
