  .edge-solid  { border-top: 2px solid #666; }
  .edge-dashed { border-top: 1px dashed #b0b0b0; }
  #citracer-info h3 { margin: 0 0 6px 0; font-size: 14px; line-height: 1.3; }
  #citracer-info .meta { color: #555; font-size: 12px; margin-bottom: 8px; }
  #citracer-info .hits { background: #fafafa; border: 1px solid #eee;
                         border-radius: 4px; padding: 8px; margin-top: 8px; }
  #citracer-info .hit-snippet { font-size: 12px; line-height: 1.45;
                                margin-bottom: 8px; padding-bottom: 8px;
                                border-bottom: 1px dashed #e0e0e0; }
  #citracer-info .hit-snippet:last-child { border-bottom: none; margin-bottom: 0; }
  #citracer-info mark { color: #222; padding: 0 2px; border-radius: 2px; }
  #citracer-info .hits-toggle {
    color: #06c; font-size: 11px; cursor: pointer; user-select: none;
    margin-top: 4px; display: inline-block;
  }
  #citracer-info .hits-toggle:hover { text-decoration: underline; }
  #citracer-info .abstract-block {
    background: #fafafa; border: 1px solid #eee; border-radius: 4px;
    padding: 6px 10px; margin-top: 8px;
  }
  #citracer-info .abstract-block summary {
    cursor: pointer; color: #06c; font-size: 11px; user-select: none;
    list-style: none;
  }
  #citracer-info .abstract-block summary::-webkit-details-marker { display: none; }
